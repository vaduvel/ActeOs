{
  "$id": "https://acteos.example/schemas/case.schema.json",
  "title": "Case",
  "type": "object",
  "required": [
    "id",
    "event_type_id",
    "reference_date",
    "timezone",
    "jurisdiction_path",
    "status",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type_id": {
      "type": "string"
    },
    "reference_date": {
      "type": "string",
      "format": "date"
    },
    "timezone": {
      "type": "string",
      "const": "Europe/Bucharest"
    },
    "jurisdiction_path": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "subject_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "facts": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "needs_facts",
        "resolved",
        "needs_confirmation",
        "conflicting",
        "blocked",
        "completed",
        "cancelled"
      ]
    },
    "version": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
