{
  "$id": "https://acteos.example/schemas/life_event.schema.json",
  "title": "Life Event Type",
  "type": "object",
  "required": [
    "id",
    "category_id",
    "title_ro",
    "release_wave"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ro\\.life\\.[a-z0-9_.-]+$"
    },
    "category_id": {
      "type": "string"
    },
    "title_ro": {
      "type": "string"
    },
    "description_ro": {
      "type": [
        "string",
        "null"
      ]
    },
    "trigger_phrases_ro": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parent_event_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "triggered_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frequency_hypothesis": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "pain_hypothesis": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "very_high"
      ]
    },
    "release_wave": {
      "type": "string"
    },
    "jurisdiction_scope": {
      "type": "string"
    },
    "research_status": {
      "type": "string"
    },
    "production_status": {
      "type": "string"
    },
    "fact_definition_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
