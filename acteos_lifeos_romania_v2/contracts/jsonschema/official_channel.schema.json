{
  "$id": "https://acteos.example/schemas/official_channel.schema.json",
  "title": "Official Channel",
  "type": "object",
  "required": [
    "id",
    "type",
    "label_ro",
    "integration_status",
    "official_domain",
    "jurisdiction_ids",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "web",
        "physical",
        "phone",
        "email",
        "deep_link"
      ]
    },
    "label_ro": {
      "type": "string"
    },
    "url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "address": {
      "type": [
        "object",
        "null"
      ]
    },
    "phone": {
      "type": [
        "string",
        "null"
      ]
    },
    "email": {
      "type": [
        "string",
        "null"
      ],
      "format": "email"
    },
    "integration_status": {
      "type": "string",
      "enum": [
        "SOURCE_ONLY",
        "DEEP_LINK",
        "ENROLMENT_REQUIRED",
        "NOT_CONFIGURED",
        "SANDBOX",
        "ACTIVE",
        "SUSPENDED"
      ]
    },
    "official_domain": {
      "type": [
        "string",
        "null"
      ]
    },
    "jurisdiction_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "stale",
        "unavailable",
        "withdrawn"
      ]
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
