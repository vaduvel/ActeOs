# Environment
APP_ENV=local
APP_VERSION=0.0.0-dev
PUBLIC_API_BASE_URL=http://localhost:8000
CURATOR_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+psycopg://waze:waze_local_only@localhost:5432/waze_birocratie
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

# Object storage — local MinIO only
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=waze-evidence-local
S3_ACCESS_KEY=local-only-change-me
S3_SECRET_KEY=local-only-change-me
S3_FORCE_PATH_STYLE=true

# Encryption — local placeholder; production uses KMS/workload identity
FIELD_ENCRYPTION_PROVIDER=local
FIELD_ENCRYPTION_KEY_ID=local-dev-v1
FIELD_ENCRYPTION_LOCAL_KEY_B64=REPLACE_WITH_32_BYTE_BASE64_LOCAL_ONLY

# Curator OIDC — disabled locally unless configured
CURATOR_OIDC_ENABLED=false
CURATOR_OIDC_ISSUER=https://auth.example.invalid/
CURATOR_OIDC_CLIENT_ID=not-configured
CURATOR_OIDC_CLIENT_SECRET=not-configured
CURATOR_OIDC_AUDIENCE=waze-curator

# Jobs
JOB_BACKEND=postgres
WORKER_CONCURRENCY=2
SOURCE_FETCH_USER_AGENT=WazeBirocratieResearchBot/1.0 (+security-contact@example.invalid)
SOURCE_FETCH_ALLOWED_SCHEMES=https
SOURCE_FETCH_MAX_BYTES=25000000
SOURCE_FETCH_TIMEOUT_SECONDS=20

# AI candidate extraction — off by default
AI_EXTRACTION_ENABLED=false
AI_PROVIDER=not-configured
AI_MODEL=not-configured
AI_API_KEY=not-configured

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
SENTRY_DSN=

# Security
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_BACKEND=memory

# Feature flags
FEATURE_CITIZEN_ACCOUNT=false
FEATURE_DOCUMENT_METADATA_SYNC=false
FEATURE_HIGH_SCHOOL=false
FEATURE_ROEID_AUTH=false
FEATURE_ANAF_OAUTH=false
FEATURE_GHISEUL_INTEGRATION=false
FEATURE_OFFICIAL_DEEP_LINKS=true
FEATURE_PUSH_RULE_CHANGE_NOTIFICATIONS=false
