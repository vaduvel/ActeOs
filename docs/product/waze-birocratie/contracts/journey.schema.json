{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/waze-birocratie/journey.schema.json",
  "title": "Resolved journey artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "intent_id",
    "jurisdiction_code",
    "evaluated_at",
    "engine_version",
    "rule_bundle_hash",
    "facts_hash",
    "route_hash",
    "status",
    "confidence",
    "steps",
    "issues"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "intent_id": {
      "type": "string"
    },
    "jurisdiction_code": {
      "type": "string"
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "engine_version": {
      "type": "string"
    },
    "rule_bundle_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "facts_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "route_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "resolved",
        "needs_facts",
        "blocked"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "verified",
        "verified_with_local_gap",
        "needs_confirmation",
        "conflicting",
        "expired"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "sequence",
          "state",
          "requirement_ids",
          "source_claim_ids"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "sequence": {
            "type": "integer",
            "minimum": 1
          },
          "state": {
            "type": "string",
            "enum": [
              "upcoming",
              "actionable",
              "blocked",
              "completed",
              "skipped"
            ]
          },
          "requirement_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "blocking",
              "warning",
              "info"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
