{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RouteRun",
  "type": "object",
  "required": ["id", "session_id", "route_hash", "status", "obligations"],
  "properties": {
    "id": { "type": "string" },
    "session_id": { "type": "string" },
    "plan_id": { "type": "string" },
    "obligation_id": { "type": "string" },
    "route_hash": { "type": "string" },
    "status": { "type": "string" },
    "obligations": { "type": "array", "items": { "type": "object" } }
  }
}
