{
  "$id": "https://acteos/schemas/predicate.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Typed Predicate",
  "type": "object",
  "required": ["op"],
  "properties": {
    "op": {
      "type": "string",
      "enum": ["const", "all", "any", "not", "eq", "neq", "in", "not_in", "lt", "lte", "gt", "gte", "exists", "missing", "contains", "date_before", "date_after", "date_between", "age_on_date_gte", "age_on_date_lt", "days_between_lte", "within_window", "jurisdiction_is", "jurisdiction_descends_from", "institution_is", "authority_scope_contains"]
    },
    "field": { "type": "string", "pattern": "^[a-zA-Z0-9_.-]+$" },
    "value": {},
    "values": { "type": "array" },
    "args": { "type": "array", "items": { "$ref": "#" } },
    "arg": { "$ref": "#" }
  },
  "allOf": [
    { "if": { "properties": { "op": { "const": "const" } } }, "then": { "required": ["value"], "properties": { "value": { "type": "boolean" } } } },
    { "if": { "properties": { "op": { "enum": ["all", "any"] } } }, "then": { "required": ["args"], "properties": { "args": { "minItems": 1 } } } },
    { "if": { "properties": { "op": { "const": "not" } } }, "then": { "required": ["arg"] } },
    { "if": { "properties": { "op": { "enum": ["eq", "neq", "lt", "lte", "gt", "gte", "contains", "date_before", "date_after", "age_on_date_gte", "age_on_date_lt", "days_between_lte", "jurisdiction_is", "jurisdiction_descends_from", "institution_is", "authority_scope_contains"] } } }, "then": { "required": ["field", "value"] } },
    { "if": { "properties": { "op": { "enum": ["in", "not_in", "date_between", "within_window"] } } }, "then": { "required": ["field", "values"], "properties": { "values": { "minItems": 2 } } } },
    { "if": { "properties": { "op": { "enum": ["exists", "missing"] } } }, "then": { "required": ["field"] } }
  ],
  "additionalProperties": false
}
