{
  "$id": "https://acteos/schemas/rule.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Administrative Rule Revision",
  "type": "object",
  "required": ["id", "canonical_rule_id", "event_type_id", "jurisdiction_ids", "severity", "effective_from", "when", "effects", "source_claim_ids", "status"],
  "properties": {
    "id": { "type": "string" },
    "canonical_rule_id": { "type": "string" },
    "event_type_id": { "type": "string", "description": "Conventie super-book: life.* (vezi 27_V2_DONOR_INTEGRATION.md)" },
    "jurisdiction_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "authority_level": { "type": "string" },
    "competence_scope": { "type": "array", "items": { "type": "string" } },
    "legal_rank": { "type": ["string", "null"] },
    "required_facts": { "type": "array", "items": { "type": "string" }, "description": "Optional: dezambiguizare facts the event collects; drives needs_facts." },
    "severity": { "type": "string", "enum": ["critical", "operational", "explanatory"] },
    "effective_from": { "type": "string", "format": "date" },
    "effective_to": { "type": ["string", "null"], "format": "date" },
    "when": { "$ref": "predicate.schema.json" },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["include_step", "exclude_step", "include_requirement", "set_requirement_obligation", "set_deadline", "attach_channel", "emit_warning", "emit_advice", "require_confirmation", "flag_conflict", "block", "override_rule", "trigger_child_event", "set_freshness_state"] },
          "step_id": { "type": "string" },
          "requirement_id": { "type": "string" },
          "channel_id": { "type": "string" },
          "rule_id": { "type": "string", "description": "Target rule id for override_rule." },
          "target_rule_id": { "type": "string", "description": "Alias accepted for override_rule target." },
          "event_type_id": { "type": "string" },
          "tag": { "type": "string", "description": "Stable grouping tag for advice/warning/confirmation/conflict; golden fixtures assert on this." },
          "blocked_effect": { "type": "string", "description": "For flag_conflict: tag of the downstream effect that cannot be shown until the conflict is resolved." },
          "obligation": { "type": "string" },
          "code": { "type": "string" },
          "value": {},
          "message_ro": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "source_claim_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "override_rule_ids": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["draft", "in_review", "approved", "active", "withdrawn", "superseded"] },
    "reviewer_id": { "type": ["string", "null"] },
    "note": { "type": "string" }
  },
  "additionalProperties": false
}
