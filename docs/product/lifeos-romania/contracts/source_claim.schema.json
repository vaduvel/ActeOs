{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceClaim",
  "type": "object",
  "required": ["id", "source_id", "quote", "locator", "confidence"],
  "properties": {
    "id": { "type": "string" },
    "source_id": { "type": "string" },
    "snapshot_id": { "type": "string" },
    "claim_type": { "type": "string" },
    "quote": { "type": "string" },
    "locator": { "type": "string" },
    "effective_from": { "type": "string", "format": "date" },
    "effective_to": { "type": "string", "format": "date" },
    "confidence": { "enum": ["verified", "verified_with_local_gap", "needs_confirmation", "conflicting", "expired", "withdrawn"] }
  }
}
