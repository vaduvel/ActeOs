{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Journey",
  "type": "object",
  "required": ["id", "title", "steps"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "applies_when": { "type": "object" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "do_now": { "type": "string" },
          "deadline": { "type": "string" },
          "requirements": { "type": "array", "items": { "type": "string" } },
          "done_when": { "type": "string" },
          "if_blocked": { "type": "string" }
        }
      }
    }
  }
}
