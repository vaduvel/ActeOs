{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rule",
  "type": "object",
  "required": [
    "id",
    "rule_type",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "rule_type": {
      "enum": [
        "event_trigger",
        "gate",
        "step",
        "requirement",
        "channel",
        "notification"
      ]
    },
    "payload": {
      "type": "object"
    },
    "source_claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "demo_mode": {
      "type": "boolean"
    }
  }
}