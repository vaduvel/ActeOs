{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Journey",
  "type": "object",
  "required": [
    "id",
    "title",
    "steps"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "applies_when": {
      "type": "object"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}