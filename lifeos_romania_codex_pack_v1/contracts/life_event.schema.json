{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LifeEventType",
  "type": "object",
  "required": [
    "id",
    "category_id",
    "label",
    "frequency_tier",
    "related_obligations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]+$"
    },
    "category_id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "frequency_tier": {
      "enum": [
        "A",
        "B",
        "C"
      ]
    },
    "r1_scope": {
      "type": "boolean"
    },
    "example_queries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}