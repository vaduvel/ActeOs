{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceClaim",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "quote",
    "locator",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "quote": {
      "type": "string"
    },
    "locator": {
      "type": "string"
    },
    "confidence": {
      "enum": [
        "verified",
        "verified_with_local_gap",
        "needs_confirmation",
        "conflicting",
        "expired"
      ]
    }
  }
}