# Runtime
APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
MOBILE_PUBLIC_API_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+psycopg://acteos:acteos@localhost:5432/acteos
DATABASE_DIRECT_URL=postgresql://acteos:acteos@localhost:5432/acteos

# Auth / Supabase reference deployment
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_AUDIENCE=acteos
JWT_ISSUER=

# Storage — disabled by default for user documents
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=acteos-content-snapshots
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# Notifications
EMAIL_PROVIDER_API_KEY=
PUSH_PROVIDER_PROJECT_ID=

# Feature gates
ENABLE_CLOUD_DOCUMENT_PROCESSING=false
ENABLE_PARTNER_DIRECTORY=false
ENABLE_LLM_RESEARCH_ASSISTANT=false
