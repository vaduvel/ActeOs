{
  "$id": "https://acteos.example/schemas/intent.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Intent Type",
  "type": "object",
  "required": [
    "id",
    "category_id",
    "kind",
    "title_ro",
    "outcome_ro",
    "aliases_ro",
    "release_wave",
    "production_status",
    "catalog_version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ro\\.intent\\.[a-z0-9_.-]+$"
    },
    "category_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "direct_goal",
        "bundle_goal"
      ]
    },
    "title_ro": {
      "type": "string",
      "minLength": 4
    },
    "outcome_ro": {
      "type": "string",
      "minLength": 4
    },
    "aliases_ro": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "negative_aliases_ro": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "linked_event_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^ro\\.life\\.[a-z0-9_.-]+$"
      }
    },
    "journey_template_id": {
      "type": "string",
      "minLength": 3
    },
    "jurisdiction_scope": {
      "type": "string"
    },
    "release_wave": {
      "type": "string"
    },
    "research_status": {
      "type": "string"
    },
    "production_status": {
      "type": "string"
    },
    "availability_policy": {
      "type": "string"
    },
    "search_boost": {
      "type": "number",
      "minimum": 0,
      "maximum": 3
    },
    "catalog_version": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
