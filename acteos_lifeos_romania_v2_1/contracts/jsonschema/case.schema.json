{
  "$id": "https://acteos.example/schemas/case.schema.json",
  "title": "Case",
  "type": "object",
  "required": [
    "id",
    "intent_type_id",
    "event_type_id",
    "reference_date",
    "timezone",
    "jurisdiction_path",
    "status",
    "version"
  ],
  "anyOf": [
    {
      "required": ["user_id"],
      "properties": {
        "user_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    {
      "required": ["installation_id"],
      "properties": {
        "installation_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "installation_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "intent_type_id": {
      "type": "string",
      "pattern": "^ro\\.intent\\.[a-z0-9_.-]+$"
    },
    "event_type_id": {
      "type": "string",
      "pattern": "^ro\\.life\\.[a-z0-9_.-]+$"
    },
    "subject_ref": {
      "type": ["string", "null"]
    },
    "reference_date": {
      "type": "string",
      "format": "date"
    },
    "timezone": {
      "type": "string",
      "const": "Europe/Bucharest"
    },
    "jurisdiction_path": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "facts": {
      "type": "object"
    },
    "discovery_source": {
      "type": ["string", "null"],
      "enum": ["search", "category", "quick_action", "related_intent", "deep_link", "legacy_event", null]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "needs_facts", "resolved", "needs_confirmation", "conflicting", "blocked", "completed", "cancelled"]
    },
    "version": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
