{
  "$id": "https://acteos.example/schemas/journey.schema.json",
  "title": "Journey",
  "type": "object",
  "required": [
    "id",
    "case_id",
    "revision",
    "event_type_id",
    "ruleset_version",
    "reference_date",
    "status",
    "steps",
    "resolution_trace"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "case_id": {
      "type": "string",
      "format": "uuid"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "event_type_id": {
      "type": "string"
    },
    "ruleset_version": {
      "type": "string"
    },
    "reference_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "needs_review",
        "completed",
        "cancelled",
        "archived",
        "blocked"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "semantic_key",
          "title_ro",
          "status",
          "sequence",
          "requirements"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "semantic_key": {
            "type": "string"
          },
          "title_ro": {
            "type": "string"
          },
          "instruction_ro": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "sequence": {
            "type": "integer"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "deadline": {
            "type": [
              "object",
              "null"
            ]
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "source_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "resolution_trace": {
      "type": "object",
      "required": [
        "facts_hash",
        "engine_version",
        "included_rule_ids"
      ],
      "properties": {
        "facts_hash": {
          "type": "string"
        },
        "engine_version": {
          "type": "string"
        },
        "included_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excluded_rule_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
