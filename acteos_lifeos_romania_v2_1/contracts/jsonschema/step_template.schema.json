{
  "$id": "https://acteos.example/schemas/step_template.schema.json",
  "title": "Step Template",
  "description": "Reusable journey step authored in a batch templates.yaml. Maps to content.step_templates. Only 'id' is required at the schema gate; the publish compiler additionally defers steps lacking title_ro/instruction_ro (honest gap) rather than fabricating them.",
  "type": "object",
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "semantic_key": {
      "type": "string",
      "minLength": 1
    },
    "title_ro": {
      "type": "string"
    },
    "instruction_ro": {
      "type": "string"
    },
    "sequence_hint": {
      "type": "integer",
      "minimum": 0
    },
    "completion_evidence_ro": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recovery_actions_ro": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
