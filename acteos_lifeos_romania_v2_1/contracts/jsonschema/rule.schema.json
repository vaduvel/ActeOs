{
  "$id": "https://acteos.example/schemas/rule.schema.json",
  "title": "Administrative Rule Revision",
  "type": "object",
  "required": [
    "id",
    "canonical_rule_id",
    "event_type_id",
    "jurisdiction_ids",
    "severity",
    "effective_from",
    "when",
    "effects",
    "source_claim_ids",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "canonical_rule_id": {
      "type": "string"
    },
    "event_type_id": {
      "type": "string"
    },
    "jurisdiction_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "authority_level": {
      "type": "string"
    },
    "competence_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "legal_rank": {
      "type": [
        "string",
        "null"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "operational",
        "explanatory"
      ]
    },
    "effective_from": {
      "type": "string",
      "format": "date"
    },
    "effective_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "when": {
      "$ref": "predicate.schema.json"
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "include_step",
              "exclude_step",
              "include_requirement",
              "set_requirement_obligation",
              "set_deadline",
              "attach_channel",
              "emit_warning",
              "emit_advice",
              "block",
              "flag_conflict",
              "require_confirmation",
              "override_rule",
              "trigger_child_event",
              "set_freshness_state"
            ]
          },
          "step_id": {
            "type": "string"
          },
          "requirement_id": {
            "type": "string"
          },
          "channel_id": {
            "type": "string"
          },
          "value": {},
          "message_ro": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "source_claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "override_rule_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "approved",
        "active",
        "withdrawn",
        "superseded"
      ]
    },
    "reviewer_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
