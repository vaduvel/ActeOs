{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {"cache": false, "persistent": true},
    "build": {"dependsOn": ["^build"], "outputs": [".next/**", "dist/**", "build/**"]},
    "lint": {"dependsOn": ["^lint"]},
    "typecheck": {"dependsOn": ["^typecheck"]},
    "test": {"dependsOn": ["^test"], "outputs": ["coverage/**"]}
  }
}
